# ── Sunucu ────────────────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=development      # development | production | test

# ── Veritabanı ────────────────────────────────────────────────────────────────
# MongoDB Atlas bağlantı URI'si
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://KULLANICI:SIFRE@cluster.mongodb.net/iscev?appName=Iscev

# ── JWT ───────────────────────────────────────────────────────────────────────
# En az 32 karakter, rastgele ve güçlü bir değer kullanın.
# Üretim: openssl rand -hex 64
JWT_SECRET=BURAYA_EN_AZ_64_KARAKTERLIK_GUCLU_BIR_SECRET_YAZIN
JWT_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────────────────────
# Birden fazla origin için virgülle ayırın
# Production: https://iscevaritma.com.tr,https://www.iscevaritma.com.tr
# Development: http://localhost:3000
CLIENT_ORIGIN=https://iscevaritma.com.tr,https://www.iscevaritma.com.tr

# ── E-posta (SMTP) ────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false           # true → port 465, false → STARTTLS
SMTP_USER=ornek@gmail.com
SMTP_PASS=gmail_uygulama_sifresi    # Gmail App Password (2FA aktifken)
SMTP_FROM_NAME=İSÇEV
SMTP_FROM_EMAIL=ornek@gmail.com

# ── Seed Kontrolü ─────────────────────────────────────────────────────────────
# true → server.js başlarken seed çalıştırır (sadece development için)
# Production'da her zaman false bırakın, elle: npm run seed
AUTO_SEED=false
